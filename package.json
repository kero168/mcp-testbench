{
  "name": "mcp-testbench",
  "version": "0.2.0",
  "description": "Test any MCP server, in any language, with one command. A test runner and conformance checker for Model Context Protocol servers.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "test-runner",
    "conformance",
    "ci",
    "quality",
    "llm",
    "ai-agents"
  ],
  "license": "MIT",
  "author": "kero168",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kero168/mcp-testbench.git"
  },
  "homepage": "https://github.com/kero168/mcp-testbench#readme",
  "bugs": {
    "url": "https://github.com/kero168/mcp-testbench/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcp-testbench": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.16.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  }
}
